#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${WORK_CONTAINER_CONFIG_DIR:-/config}"
VPN_ENV_FILE="${WORK_CONTAINER_VPN_ENV_FILE:-${CONFIG_DIR}/vpn.env}"
VPN_TEMPLATE_FILE="${WORK_CONTAINER_SWANCTL_TEMPLATE:-${CONFIG_DIR}/swanctl.conf.template}"
PROXY_TEMPLATE_FILE="${WORK_CONTAINER_TINYPROXY_TEMPLATE:-${CONFIG_DIR}/tinyproxy.conf.template}"
PROXY_CONFIG_FILE="${WORK_CONTAINER_TINYPROXY_CONFIG:-/etc/tinyproxy/tinyproxy.conf}"
PROJECT_CERTS_DIR="${WORK_CONTAINER_PROJECT_CERTS_DIR:-/project-certs}"

if [[ -f "${VPN_ENV_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${VPN_ENV_FILE}"
fi

: "${VPN_CONN:=default}"
: "${VPN_CHILD:=default-child}"
: "${VPN_SERVER:?Set VPN_SERVER in ${VPN_ENV_FILE}}"
: "${VPN_REMOTE_ID:?Set VPN_REMOTE_ID in ${VPN_ENV_FILE}}"
: "${VPN_USERNAME:?Set VPN_USERNAME in ${VPN_ENV_FILE}}"
: "${VPN_PASSWORD:?Set VPN_PASSWORD in ${VPN_ENV_FILE}}"
: "${VPN_LOCAL_ID:=%any}"
: "${VPN_IKE_PROPOSAL:=aes256-sha256-modp2048}"
: "${VPN_ESP_PROPOSAL:=aes256-sha256}"
: "${VPN_SERVER_ADDR:=}"

if [[ ! -f "${VPN_TEMPLATE_FILE}" ]]; then
  echo "Missing template: ${VPN_TEMPLATE_FILE}" >&2
  exit 1
fi

IPSEC_BIN="$(command -v ipsec)"
SWANCTL_BIN="$(command -v swanctl)"
TINYPROXY_BIN="$(command -v tinyproxy || true)"
NODE_PROXY_PORT="${WORK_CONTAINER_NODE_PROXY_PORT:-3128}"
PROXY_STATUS_LINE="HTTP proxy: unavailable"

ensure_ip_rule_to_main() {
  local target_ip="$1"
  local pref="$2"
  local rule="to ${target_ip}/32 lookup main"
  if ip rule show | grep -Fq "${rule}"; then
    return
  fi
  ip rule add pref "${pref}" to "${target_ip}/32" lookup main
}

DEFAULT_IFACE="$(ip route show default | awk '/default/ {print $5; exit}')"
if [[ -z "${DEFAULT_IFACE}" ]]; then
  echo "Could not detect default network interface" >&2
  exit 1
fi
HOST_GATEWAY_IP="$(ip route show default | awk '/default/ {print $3; exit}')"
if [[ -z "${HOST_GATEWAY_IP}" ]]; then
  echo "Could not detect default gateway IP" >&2
  exit 1
fi

VPN_SERVER_IP="$(getent ahostsv4 "${VPN_SERVER}" | awk '{print $1; exit}')"
if [[ -z "${VPN_SERVER_IP}" ]]; then
  echo "Could not resolve VPN_SERVER=${VPN_SERVER}" >&2
  exit 1
fi
if [[ -z "${VPN_SERVER_ADDR}" ]]; then
  VPN_SERVER_ADDR="${VPN_SERVER_IP}"
fi

mkdir -p /etc/swanctl
export VPN_CONN VPN_CHILD VPN_SERVER VPN_SERVER_ADDR VPN_REMOTE_ID VPN_USERNAME VPN_PASSWORD VPN_LOCAL_ID VPN_IKE_PROPOSAL VPN_ESP_PROPOSAL
envsubst < "${VPN_TEMPLATE_FILE}" > /etc/swanctl/swanctl.conf

mkdir -p /etc/swanctl/x509ca
# Project certs first (portable snapshot + custom additions), then live host certs.
if compgen -G "${PROJECT_CERTS_DIR}/host/*.pem" >/dev/null; then
  cp -f "${PROJECT_CERTS_DIR}/host/"*.pem /etc/swanctl/x509ca/ 2>/dev/null || true
fi
if compgen -G "${PROJECT_CERTS_DIR}/custom/*.pem" >/dev/null; then
  cp -f "${PROJECT_CERTS_DIR}/custom/"*.pem /etc/swanctl/x509ca/ 2>/dev/null || true
fi
if compgen -G "/etc/ssl/certs/*.pem" >/dev/null; then
  cp -f /etc/ssl/certs/*.pem /etc/swanctl/x509ca/ 2>/dev/null || true
fi

echo "Applying kill-switch firewall rules..."
iptables -F
iptables -t nat -F
iptables -X
iptables -P INPUT DROP
iptables -P FORWARD DROP
iptables -P OUTPUT DROP

iptables -A INPUT -i lo -j ACCEPT
iptables -A OUTPUT -o lo -j ACCEPT
iptables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
iptables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
iptables -A INPUT -p tcp --dport "${NODE_PROXY_PORT}" -j ACCEPT
# Allow TCP to host bridge gateway for dev servers / Chrome.
iptables -A OUTPUT -o "${DEFAULT_IFACE}" -d "${HOST_GATEWAY_IP}" -p tcp -j ACCEPT
iptables -A OUTPUT -o "${DEFAULT_IFACE}" -d "${VPN_SERVER_IP}" -p udp --dport 500 -j ACCEPT
iptables -A OUTPUT -o "${DEFAULT_IFACE}" -d "${VPN_SERVER_IP}" -p udp --dport 4500 -j ACCEPT
iptables -A OUTPUT -m policy --pol ipsec --dir out -j ACCEPT
iptables -A INPUT -m policy --pol ipsec --dir in -j ACCEPT

# Keep host-bound traffic on the bridge route (main table), not VPN policy table.
ensure_ip_rule_to_main "${HOST_GATEWAY_IP}" 100

echo "Starting strongSwan..."
"${IPSEC_BIN}" start
sleep 1

echo "Loading and initiating ${VPN_CONN}..."
if ! "${SWANCTL_BIN}" --load-all; then
  echo "Initial swanctl load failed; watchdog will keep retrying." >&2
fi
if ! "${SWANCTL_BIN}" --initiate --child "${VPN_CHILD}"; then
  echo "Initial VPN initiate failed; watchdog will keep retrying." >&2
fi

for _ in $(seq 1 20); do
  if "${SWANCTL_BIN}" --list-sas | grep -q "${VPN_CONN}"; then
    break
  fi
  sleep 1
done

if ! "${SWANCTL_BIN}" --list-sas | grep -q "${VPN_CONN}"; then
  echo "VPN did not come up yet; container stays running and watchdog will keep retrying." >&2
fi

if [[ -n "${TINYPROXY_BIN}" ]]; then
  if [[ ! -f "${PROXY_TEMPLATE_FILE}" ]]; then
    echo "Missing template: ${PROXY_TEMPLATE_FILE}; HTTP proxy disabled." >&2
  else
    mkdir -p "$(dirname "${PROXY_CONFIG_FILE}")"
    mkdir -p /run/tinyproxy
    chown nobody:nogroup /run/tinyproxy
    chmod 755 /run/tinyproxy
    export NODE_PROXY_PORT
    envsubst < "${PROXY_TEMPLATE_FILE}" > "${PROXY_CONFIG_FILE}"
    chmod 644 "${PROXY_CONFIG_FILE}"
    echo "Starting HTTP proxy on port ${NODE_PROXY_PORT}..."
    "${TINYPROXY_BIN}" -d -c "${PROXY_CONFIG_FILE}" &
    TINYPROXY_PID=$!
    sleep 1
    if ! kill -0 "${TINYPROXY_PID}" 2>/dev/null; then
      echo "tinyproxy failed to start; container will continue without HTTP proxy." >&2
    else
      PROXY_STATUS_LINE="HTTP proxy: http://127.0.0.1:${NODE_PROXY_PORT}"
    fi
  fi
else
  echo "tinyproxy is unavailable; HTTP proxy disabled."
fi

PUBLIC_IP="$(curl -4 --max-time 10 -fsSL ifconfig.me 2>/dev/null || true)"
if [[ -n "${PUBLIC_IP}" ]]; then
  echo "Public egress IP: ${PUBLIC_IP}"
else
  echo "Public egress IP: unavailable"
fi
echo "${PROXY_STATUS_LINE}"

echo "Runtime status:"
if [[ -n "${DISPLAY:-}" ]] && [[ -d /tmp/.X11-unix ]]; then
  echo "  X11: OK (DISPLAY=${DISPLAY})"
else
  echo "  X11: missing (DISPLAY or /tmp/.X11-unix)"
fi

if [[ -n "${WAYLAND_DISPLAY:-}" ]] && [[ -n "${XDG_RUNTIME_DIR:-}" ]] && [[ -S "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}" ]]; then
  echo "  Wayland: OK (${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY})"
else
  echo "  Wayland: missing (WAYLAND_DISPLAY/XDG_RUNTIME_DIR/socket)"
fi

if [[ -e /dev/dri/renderD128 ]]; then
  echo "  GPU render node: OK (/dev/dri/renderD128)"
else
  echo "  GPU render node: missing (/dev/dri/renderD128)"
fi

if [[ -d /dev/snd ]]; then
  echo "  ALSA device: OK (/dev/snd)"
else
  echo "  ALSA device: missing (/dev/snd)"
fi

if [[ -n "${PULSE_SERVER:-}" ]]; then
  echo "  PulseAudio env: OK (${PULSE_SERVER})"
else
  echo "  PulseAudio env: not set"
fi

echo "VPN is up. Starting command: $*"

vpn_watchdog() {
  local failures=0
  while true; do
    sleep 30

    if "${SWANCTL_BIN}" --list-sas 2>/dev/null | grep -q "${VPN_CHILD}"; then
      failures=0
      continue
    fi

    echo "VPN watchdog: CHILD_SA missing, trying to re-initiate ${VPN_CHILD}..."
    if "${SWANCTL_BIN}" --initiate --child "${VPN_CHILD}" >/dev/null 2>&1; then
      failures=0
      continue
    fi

    failures=$((failures + 1))
    if (( failures < 3 )); then
      continue
    fi

    echo "VPN watchdog: repeated CHILD_SA failures, restarting strongSwan..."
    "${IPSEC_BIN}" stop >/dev/null 2>&1 || true
    sleep 1
    "${IPSEC_BIN}" start >/dev/null 2>&1 || true
    sleep 1
    "${SWANCTL_BIN}" --load-all >/dev/null 2>&1 || true
    "${SWANCTL_BIN}" --initiate --child "${VPN_CHILD}" >/dev/null 2>&1 || true
    failures=0
  done
}

vpn_watchdog &
exec "$@"
