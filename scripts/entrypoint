#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${WORK_CONTAINER_CONFIG_DIR:-/config}"
VPN_ENV_FILE="${WORK_CONTAINER_VPN_ENV_FILE:-${CONFIG_DIR}/vpn.env}"
VPN_TEMPLATE_FILE="${WORK_CONTAINER_SWANCTL_TEMPLATE:-${CONFIG_DIR}/swanctl.conf.template}"
PROXY_TEMPLATE_FILE="${WORK_CONTAINER_TINYPROXY_TEMPLATE:-${CONFIG_DIR}/tinyproxy.conf.template}"
PROXY_CONFIG_FILE="${WORK_CONTAINER_TINYPROXY_CONFIG:-/etc/tinyproxy/tinyproxy.conf}"
PROJECT_CERTS_DIR="${WORK_CONTAINER_PROJECT_CERTS_DIR:-/project-certs}"

if [[ -f "${VPN_ENV_FILE}" ]]; then
  # shellcheck disable=SC1090
  source "${VPN_ENV_FILE}"
fi

: "${VPN_CONN:=default}"
: "${VPN_CHILD:=default-child}"
: "${VPN_SERVER:?Set VPN_SERVER in ${VPN_ENV_FILE}}"
: "${VPN_REMOTE_ID:?Set VPN_REMOTE_ID in ${VPN_ENV_FILE}}"
: "${VPN_USERNAME:?Set VPN_USERNAME in ${VPN_ENV_FILE}}"
: "${VPN_PASSWORD:?Set VPN_PASSWORD in ${VPN_ENV_FILE}}"
: "${VPN_LOCAL_ID:=%any}"
: "${VPN_IKE_PROPOSAL:=aes256-sha256-modp2048}"
: "${VPN_ESP_PROPOSAL:=aes256-sha256}"
: "${VPN_SERVER_ADDR:=}"

if [[ ! -f "${VPN_TEMPLATE_FILE}" ]]; then
  echo "Missing template: ${VPN_TEMPLATE_FILE}" >&2
  exit 1
fi

IPSEC_BIN="$(command -v ipsec)"
SWANCTL_BIN="$(command -v swanctl)"
TINYPROXY_BIN="$(command -v tinyproxy || true)"
NODE_PROXY_PORT="${WORK_CONTAINER_NODE_PROXY_PORT:-3128}"
PROXY_STATUS_LINE="HTTP proxy: unavailable"

ensure_ip_rule_to_main() {
  local target_ip="$1"
  local pref="$2"
  local rule="to ${target_ip}/32 lookup main"
  if ip rule show | grep -Fq "${rule}"; then
    return
  fi
  ip rule add pref "${pref}" to "${target_ip}/32" lookup main
}

DEFAULT_IFACE="$(ip route show default | awk '/default/ {print $5; exit}')"
if [[ -z "${DEFAULT_IFACE}" ]]; then
  echo "Could not detect default network interface" >&2
  exit 1
fi
HOST_GATEWAY_IP="$(ip route show default | awk '/default/ {print $3; exit}')"
if [[ -z "${HOST_GATEWAY_IP}" ]]; then
  echo "Could not detect default gateway IP" >&2
  exit 1
fi

CONTAINER_IFACE_MTU="${WORK_CONTAINER_IFACE_MTU:-1400}"
if ip link set dev "${DEFAULT_IFACE}" mtu "${CONTAINER_IFACE_MTU}" 2>/dev/null; then
  echo "Set ${DEFAULT_IFACE} MTU to ${CONTAINER_IFACE_MTU} (IPsec/Podman path)"
fi

VPN_SERVER_IP="$(getent ahostsv4 "${VPN_SERVER}" | awk '{print $1; exit}')"
if [[ -z "${VPN_SERVER_IP}" ]]; then
  echo "Could not resolve VPN_SERVER=${VPN_SERVER}" >&2
  exit 1
fi
if [[ -z "${VPN_SERVER_ADDR}" ]]; then
  VPN_SERVER_ADDR="${VPN_SERVER_IP}"
fi

mkdir -p /etc/swanctl
export VPN_CONN VPN_CHILD VPN_SERVER VPN_SERVER_ADDR VPN_REMOTE_ID VPN_USERNAME VPN_PASSWORD VPN_LOCAL_ID VPN_IKE_PROPOSAL VPN_ESP_PROPOSAL
envsubst < "${VPN_TEMPLATE_FILE}" > /etc/swanctl/swanctl.conf

mkdir -p /etc/swanctl/x509ca
# Project certs first (portable snapshot + custom additions), then live host certs.
if compgen -G "${PROJECT_CERTS_DIR}/host/*.pem" >/dev/null; then
  cp -f "${PROJECT_CERTS_DIR}/host/"*.pem /etc/swanctl/x509ca/ 2>/dev/null || true
fi
if compgen -G "${PROJECT_CERTS_DIR}/custom/*.pem" >/dev/null; then
  cp -f "${PROJECT_CERTS_DIR}/custom/"*.pem /etc/swanctl/x509ca/ 2>/dev/null || true
fi
if compgen -G "/etc/ssl/certs/*.pem" >/dev/null; then
  cp -f /etc/ssl/certs/*.pem /etc/swanctl/x509ca/ 2>/dev/null || true
fi

apply_killswitch_firewall() {
  echo "Applying kill-switch firewall rules..."

  # IPv4 kill-switch (same policy as original design):
  # - Internet only via IPsec policy match (full tunnel).
  # - IKE only as UDP/500 and UDP/4500 to VPN_SERVER_IP on the bridge iface.
  # - Host bridge gateway TCP in/out for: tinyproxy (published port), ngrok http backend
  #   (container -> 10.88.0.1:<host-port>), dev/Chrome host relays.
  # - Node HTTP proxy: INPUT dport NODE_PROXY_PORT; upstream uses IPsec like any app.
  iptables -F
  iptables -t nat -F
  iptables -X
  iptables -P INPUT DROP
  iptables -P FORWARD DROP
  iptables -P OUTPUT DROP

  iptables -A INPUT -i lo -j ACCEPT
  iptables -A OUTPUT -o lo -j ACCEPT
  iptables -A INPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
  iptables -A OUTPUT -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
  iptables -A INPUT -p tcp --dport "${NODE_PROXY_PORT}" -j ACCEPT
  # Outbound TCP to bridge gateway only (host dev/Chrome, ngrok backend); not general internet.
  iptables -A OUTPUT -o "${DEFAULT_IFACE}" -d "${HOST_GATEWAY_IP}" -p tcp -j ACCEPT
  iptables -A OUTPUT -o "${DEFAULT_IFACE}" -d "${VPN_SERVER_IP}" -p udp --dport 500 -j ACCEPT
  iptables -A OUTPUT -o "${DEFAULT_IFACE}" -d "${VPN_SERVER_IP}" -p udp --dport 4500 -j ACCEPT
  iptables -A OUTPUT -m policy --pol ipsec --dir out -j ACCEPT
  iptables -A INPUT -m policy --pol ipsec --dir in -j ACCEPT

  # Mangle: clamp TCP MSS on IPsec egress (kernel-netlink.mss handles SA path; INPUT policy match unsupported here).
  iptables -t mangle -F
  iptables -t mangle -A OUTPUT -m policy --pol ipsec --dir out -p tcp -m tcp \
    --tcp-flags SYN,RST SYN -j TCPMSS --clamp-mss-to-pmtu

  # --- IPv6: separate stack; DROP all (iptables does not filter IPv6). ---
  if command -v ip6tables >/dev/null 2>&1; then
    ip6tables -F
    ip6tables -t mangle -F 2>/dev/null || true
    ip6tables -t nat -F 2>/dev/null || true
    ip6tables -X 2>/dev/null || true
    ip6tables -P INPUT DROP
    ip6tables -P FORWARD DROP
    ip6tables -P OUTPUT DROP
    ip6tables -A INPUT -i lo -j ACCEPT
    ip6tables -A OUTPUT -o lo -j ACCEPT
  fi

  # Prefer IPv4 in apps; sysctl from podman run is the primary off switch.
  if [[ -w /proc/sys/net/ipv6/conf/all/disable_ipv6 ]]; then
    echo 1 >/proc/sys/net/ipv6/conf/all/disable_ipv6
    echo 1 >/proc/sys/net/ipv6/conf/default/disable_ipv6
  fi
}

apply_killswitch_firewall

# Keep host-bound traffic on the bridge route (main table), not VPN policy table.
ensure_ip_rule_to_main "${HOST_GATEWAY_IP}" 100

# VPN status messages — wording lives here only.
readonly VPN_MSG_EGRESS_UNAVAILABLE='Public egress IP: unavailable'
readonly VPN_MSG_EGRESS_FORMAT='Public egress IP: %s'
readonly VPN_MSG_WATCHDOG_PREFIX='VPN watchdog: '
readonly VPN_MSG_NETWORK_OK='VPN watchdog: network OK (tunnel and DNS working again)'
readonly VPN_MSG_CHILD_MISSING='VPN watchdog: CHILD_SA missing, trying to re-initiate %s...'
readonly VPN_MSG_DNS_FAIL='VPN watchdog: CHILD_SA up but DNS not working, re-initiating %s...'
readonly VPN_MSG_RESTART_STRONGSWAN='VPN watchdog: repeated failures, restarting strongSwan...'
readonly VPN_MSG_INITIATE_FAILED='Initial VPN initiate failed; watchdog will keep retrying.'
readonly VPN_MSG_NOT_READY_STARTUP='VPN not ready yet (tunnel or DNS); watchdog will keep retrying.'
readonly VPN_MSG_UP_START='VPN is up (tunnel and DNS OK). Starting command: %s'
readonly VPN_MSG_NOT_READY_START='VPN not ready yet; watchdog will keep retrying. Starting command: %s'

vpn_child_installed() {
  "${SWANCTL_BIN}" --list-sas 2>/dev/null | grep -qE "${VPN_CHILD}:.*INSTALLED|${VPN_CHILD}\{"
}

vpn_dns_ready() {
  getent ahostsv4 one.one.one.one >/dev/null 2>&1
}

vpn_is_ready() {
  vpn_child_installed && vpn_dns_ready
}

vpn_fetch_public_egress_ip() {
  curl -4 --max-time 10 -fsSL ifconfig.me 2>/dev/null || true
}

vpn_status_egress() {
  local prefix="${1:-}"
  local ip="${2-}"
  if [[ -n "${ip}" ]]; then
    # shellcheck disable=SC2059
    printf '%s'"${VPN_MSG_EGRESS_FORMAT}"'\n' "${prefix}" "${ip}"
  else
    printf '%s%s\n' "${prefix}" "${VPN_MSG_EGRESS_UNAVAILABLE}"
  fi
}

# prefix: optional log prefix; do_fetch: 1=curl ifconfig.me, 0=report unavailable without curl.
vpn_log_public_egress() {
  local prefix="${1:-}"
  local do_fetch="${2:-1}"
  local ip=""
  if (( do_fetch )); then
    ip="$(vpn_fetch_public_egress_ip)"
  fi
  vpn_status_egress "${prefix}" "${ip}"
}

vpn_log_watchdog_recovery() {
  echo "${VPN_MSG_NETWORK_OK}"
  vpn_log_public_egress "${VPN_MSG_WATCHDOG_PREFIX}" 1
}

vpn_try_initiate() {
  "${SWANCTL_BIN}" --load-all >/dev/null 2>&1 || return 1
  "${SWANCTL_BIN}" --initiate --child "${VPN_CHILD}" >/dev/null 2>&1
}

vpn_try_initiate_and_wait() {
  vpn_try_initiate || return 1
  sleep 3
  vpn_is_ready
}

vpn_wait_ready() {
  local max_wait="${1:-90}"
  local i=0
  while (( i < max_wait )); do
    if vpn_is_ready; then
      return 0
    fi
    sleep 1
    i=$((i + 1))
  done
  return 1
}

vpn_watchdog() {
  local failures=0
  local interval=5
  local was_healthy="${1:-0}"

  watchdog_recovered() {
    vpn_log_watchdog_recovery
    was_healthy=1
    failures=0
    interval=30
    sleep "${interval}"
  }

  while true; do
    if vpn_is_ready; then
      if (( ! was_healthy )); then
        watchdog_recovered
        continue
      fi
      failures=0
      interval=30
      sleep "${interval}"
      continue
    fi

    was_healthy=0

    if vpn_child_installed; then
      # shellcheck disable=SC2059
      printf "${VPN_MSG_DNS_FAIL}\n" "${VPN_CHILD}"
      "${SWANCTL_BIN}" --terminate --ike "${VPN_CONN}" >/dev/null 2>&1 || true
      sleep 2
    else
      # shellcheck disable=SC2059
      printf "${VPN_MSG_CHILD_MISSING}\n" "${VPN_CHILD}"
    fi

    if vpn_try_initiate_and_wait; then
      if (( ! was_healthy )); then
        watchdog_recovered
        continue
      fi
      failures=0
      interval=30
      sleep "${interval}"
      continue
    fi

    failures=$((failures + 1))
    if (( failures >= 3 )); then
      echo "${VPN_MSG_RESTART_STRONGSWAN}"
      "${IPSEC_BIN}" stop >/dev/null 2>&1 || true
      sleep 1
      "${IPSEC_BIN}" start >/dev/null 2>&1 || true
      sleep 1
      if vpn_try_initiate_and_wait; then
        watchdog_recovered
        continue
      fi
      failures=0
    fi

    interval=5
    sleep "${interval}"
  done
}

echo "Starting strongSwan..."
"${IPSEC_BIN}" start
sleep 1

echo "Loading and initiating ${VPN_CONN}..."
if ! vpn_try_initiate; then
  echo "${VPN_MSG_INITIATE_FAILED}" >&2
fi

VPN_READY=0
if vpn_wait_ready 90; then
  VPN_READY=1
else
  echo "${VPN_MSG_NOT_READY_STARTUP}" >&2
fi

# Start watchdog only after the first connect attempt (avoids false "CHILD_SA missing" while IKE is still starting).
vpn_watchdog "${VPN_READY}" &

if [[ -n "${TINYPROXY_BIN}" ]]; then
  if [[ ! -f "${PROXY_TEMPLATE_FILE}" ]]; then
    echo "Missing template: ${PROXY_TEMPLATE_FILE}; HTTP proxy disabled." >&2
  else
    mkdir -p "$(dirname "${PROXY_CONFIG_FILE}")"
    mkdir -p /run/tinyproxy
    chown nobody:nogroup /run/tinyproxy
    chmod 755 /run/tinyproxy
    export NODE_PROXY_PORT
    envsubst < "${PROXY_TEMPLATE_FILE}" > "${PROXY_CONFIG_FILE}"
    chmod 644 "${PROXY_CONFIG_FILE}"
    echo "Starting HTTP proxy on port ${NODE_PROXY_PORT}..."
    "${TINYPROXY_BIN}" -d -c "${PROXY_CONFIG_FILE}" &
    TINYPROXY_PID=$!
    sleep 1
    if ! kill -0 "${TINYPROXY_PID}" 2>/dev/null; then
      echo "tinyproxy failed to start; container will continue without HTTP proxy." >&2
    else
      PROXY_STATUS_LINE="HTTP proxy: http://127.0.0.1:${NODE_PROXY_PORT}"
    fi
  fi
else
  echo "tinyproxy is unavailable; HTTP proxy disabled."
fi

vpn_log_public_egress "" "${VPN_READY}"
echo "${PROXY_STATUS_LINE}"

echo "Runtime status:"
if [[ -n "${DISPLAY:-}" ]] && [[ -d /tmp/.X11-unix ]]; then
  echo "  X11: OK (DISPLAY=${DISPLAY})"
else
  echo "  X11: missing (DISPLAY or /tmp/.X11-unix)"
fi

if [[ -n "${WAYLAND_DISPLAY:-}" ]] && [[ -n "${XDG_RUNTIME_DIR:-}" ]] && [[ -S "${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}" ]]; then
  echo "  Wayland: OK (${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY})"
else
  echo "  Wayland: missing (WAYLAND_DISPLAY/XDG_RUNTIME_DIR/socket)"
fi

if [[ -e /dev/dri/renderD128 ]]; then
  echo "  GPU render node: OK (/dev/dri/renderD128)"
else
  echo "  GPU render node: missing (/dev/dri/renderD128)"
fi

if [[ -d /dev/snd ]]; then
  echo "  ALSA device: OK (/dev/snd)"
else
  echo "  ALSA device: missing (/dev/snd)"
fi

if [[ -n "${PULSE_SERVER:-}" ]]; then
  echo "  PulseAudio env: OK (${PULSE_SERVER})"
else
  echo "  PulseAudio env: not set"
fi

if (( VPN_READY )); then
  # shellcheck disable=SC2059
  printf "${VPN_MSG_UP_START}\n" "$*"
else
  # shellcheck disable=SC2059
  printf "${VPN_MSG_NOT_READY_START}\n" "$*"
fi

exec "$@"
