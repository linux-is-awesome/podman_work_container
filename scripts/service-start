#!/usr/bin/env bash
set -euo pipefail

PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "${PROJECT_DIR}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -x "${SCRIPT_DIR}/sync-certs" ]]; then
  "${SCRIPT_DIR}/sync-certs" >/dev/null
fi
source "${SCRIPT_DIR}/image-utils"
source "${SCRIPT_DIR}/host-mounts"
source "${SCRIPT_DIR}/host-gtk-settings"
source "${SCRIPT_DIR}/runtime-status"

IMAGE_NAME_PREFIX="work_container"
CONTAINER_NAME="work_container"
CONFIG_DIR="${PROJECT_DIR}/config"
IMAGE_DIR="${PROJECT_DIR}/containers"
CERTS_DIR="${PROJECT_DIR}/certs"
REQUESTED_VERSION="${1:-}"
PODMAN_BIN_CMD="${WORK_CONTAINER_PODMAN_BIN:-sudo podman}"
read -r -a PODMAN_BIN <<< "${PODMAN_BIN_CMD}"
HOST_HOME="${WORK_CONTAINER_HOST_HOME:-${HOME}}"
HOST_UID="${WORK_CONTAINER_HOST_UID:-$(id -u)}"
HOST_GID="${WORK_CONTAINER_HOST_GID:-$(id -g)}"
HOST_RUNTIME_DIR="${WORK_CONTAINER_HOST_RUNTIME_DIR:-/run/user/${HOST_UID}}"
IMAGE_DIR="${WORK_CONTAINER_IMAGE_DIR:-${IMAGE_DIR}}"
HOST_WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-}"
HOST_TIMEZONE="${TZ:-}"
WAIT_FOR_GUI="${WORK_CONTAINER_WAIT_FOR_GUI:-0}"
WAIT_FOR_GUI_TIMEOUT="${WORK_CONTAINER_WAIT_FOR_GUI_TIMEOUT:-180}"
WAIT_FOR_PAYLOAD="${WORK_CONTAINER_WAIT_FOR_PAYLOAD:-1}"
WAIT_FOR_PAYLOAD_TIMEOUT="${WORK_CONTAINER_WAIT_FOR_PAYLOAD_TIMEOUT:-180}"

wait_for_gui_readiness() {
  local waited=0
  local step=2
  local wayland_sock="${HOST_RUNTIME_DIR}/wayland-0"
  local pulse_sock="${HOST_RUNTIME_DIR}/pulse/native"

  if [[ "${WAIT_FOR_GUI}" != "1" ]]; then
    return
  fi

  echo "Waiting for graphical session resources (Wayland/Pulse/GPU)..."
  while (( waited < WAIT_FOR_GUI_TIMEOUT )); do
    if [[ -S "${wayland_sock}" ]] && [[ -S "${pulse_sock}" ]] && [[ -e /dev/dri/renderD128 ]]; then
      echo "Graphical session resources detected."
      return
    fi
    sleep "${step}"
    waited=$((waited + step))
  done

  echo "Graphical resources not fully ready after ${WAIT_FOR_GUI_TIMEOUT}s; continuing startup."
}

wait_for_payload() {
  local waited=0
  local step=2
  local latest_image=""

  if [[ "${WAIT_FOR_PAYLOAD}" != "1" ]]; then
    return
  fi

  echo "Waiting for container payload in ${IMAGE_DIR}..."
  while (( waited < WAIT_FOR_PAYLOAD_TIMEOUT )); do
    if [[ -d "${IMAGE_DIR}" ]]; then
      latest_image="$(find_latest_image "${IMAGE_DIR}")"
      if [[ -n "${latest_image}" ]]; then
        echo "Container payload detected."
        return
      fi
    fi
    sleep "${step}"
    waited=$((waited + step))
  done

  echo "No payload detected after ${WAIT_FOR_PAYLOAD_TIMEOUT}s; skipping container start."
}

ensure_host_runtime_dir() {
  if [[ ! -d "${HOST_RUNTIME_DIR}" ]]; then
    mkdir -p "${HOST_RUNTIME_DIR}"
  fi
  chown "${HOST_UID}:${HOST_GID}" "${HOST_RUNTIME_DIR}"
  chmod 700 "${HOST_RUNTIME_DIR}"
}

if [[ ! -f "${CONFIG_DIR}/vpn.env" ]]; then
  echo "Missing ${CONFIG_DIR}/vpn.env. Run ./start configure-vpn first." >&2
  exit 1
fi
if [[ ! -f "${CONFIG_DIR}/swanctl.conf.template" ]]; then
  echo "Missing ${CONFIG_DIR}/swanctl.conf.template" >&2
  exit 1
fi

if [[ -f "${CONFIG_DIR}/proxy.env" ]]; then
  # shellcheck disable=SC1090
  source "${CONFIG_DIR}/proxy.env"
fi
NODE_PROXY_PORT="${WORK_CONTAINER_NODE_PROXY_PORT:-3128}"

wait_for_payload

if [[ ! -d "${IMAGE_DIR}" ]]; then
  echo "Image file directory not found: ${IMAGE_DIR}"
  echo "No payload installed; skipping container start."
  exit 0
fi

LATEST_IMAGE="$(find_latest_image "${IMAGE_DIR}")"
if [[ -z "${LATEST_IMAGE}" ]]; then
  echo "No container image files found in ${IMAGE_DIR}/."
  echo "No payload installed; skipping container start."
  exit 0
fi

if [[ -n "${REQUESTED_VERSION}" ]]; then
  IMAGE_PATH="${IMAGE_DIR}/work_container-${REQUESTED_VERSION}.oci"
  if [[ ! -f "${IMAGE_PATH}" ]]; then
    echo "Build version not found: ${REQUESTED_VERSION}" >&2
    exit 1
  fi
else
  IMAGE_PATH="${LATEST_IMAGE}"
fi

BUILD_VERSION="$(image_version_from_path "${IMAGE_PATH}")"
IMAGE_NAME="${IMAGE_NAME_PREFIX}:${BUILD_VERSION}"

echo "Loading image from ${IMAGE_PATH}..."
"${PODMAN_BIN[@]}" load -i "${IMAGE_PATH}" >/dev/null

wait_for_gui_readiness
ensure_host_runtime_dir
if [[ -z "${HOST_WAYLAND_DISPLAY}" ]] && [[ -S "${HOST_RUNTIME_DIR}/wayland-0" ]]; then
  HOST_WAYLAND_DISPLAY="wayland-0"
fi
HOST_STATUS="$(print_runtime_status_for_host "${DISPLAY:-}" "${HOST_WAYLAND_DISPLAY:-}" "${HOST_RUNTIME_DIR}" "unix:${HOST_RUNTIME_DIR}/pulse/native")"

DISPLAY_ARGS=()
if [[ -d /tmp/.X11-unix ]]; then
  DISPLAY_ARGS+=("-v" "/tmp/.X11-unix:/tmp/.X11-unix:rw")
fi
if [[ -d "${HOST_RUNTIME_DIR}" ]]; then
  DISPLAY_ARGS+=("-v" "${HOST_RUNTIME_DIR}:${HOST_RUNTIME_DIR}:rw")
fi
if [[ -d /dev/dri ]]; then
  DISPLAY_ARGS+=("--device" "/dev/dri:/dev/dri:rwm")
fi
if [[ -d /dev/snd ]]; then
  DISPLAY_ARGS+=("--device" "/dev/snd:/dev/snd:rwm")
fi
if [[ -S /run/dbus/system_bus_socket ]]; then
  DISPLAY_ARGS+=("-v" "/run/dbus/system_bus_socket:/run/dbus/system_bus_socket:rw")
fi
if [[ -f /etc/localtime ]]; then
  DISPLAY_ARGS+=("-v" "/etc/localtime:/etc/localtime:ro")
fi
if [[ -f /etc/timezone ]]; then
  DISPLAY_ARGS+=("-v" "/etc/timezone:/etc/timezone:ro")
fi
add_host_mounts DISPLAY_ARGS "${SCRIPT_DIR}" "${HOST_HOME}"
prepare_host_gtk_settings_mounts DISPLAY_ARGS "${HOST_HOME}" "${HOST_RUNTIME_DIR}" "${HOST_UID}"

"${PODMAN_BIN[@]}" rm -f "${CONTAINER_NAME}" >/dev/null 2>&1 || true

echo "Starting service container ${CONTAINER_NAME} from ${IMAGE_NAME}..."
"${PODMAN_BIN[@]}" run -d --name "${CONTAINER_NAME}" --hostname "${CONTAINER_NAME}" \
  --network bridge \
  --group-add keep-groups \
  --device-cgroup-rule "c 226:* rwm" \
  --device-cgroup-rule "c 116:* rwm" \
  --shm-size=1g \
  --cap-add NET_ADMIN \
  --cap-add NET_RAW \
  --sysctl net.ipv6.conf.all.disable_ipv6=1 \
  --sysctl net.ipv6.conf.default.disable_ipv6=1 \
  --device /dev/net/tun \
  --security-opt label=disable \
  --security-opt apparmor=unconfined \
  -v "${CONFIG_DIR}:/config:ro" \
  -v "${CERTS_DIR}:/project-certs:ro" \
  -v "/etc/passwd:/etc/passwd:ro" \
  -v "/etc/group:/etc/group:ro" \
  -v "${HOST_HOME}:${HOST_HOME}:rw" \
  -e "HOME=${HOST_HOME}" \
  -w "${HOST_HOME}" \
  -e "XDG_RUNTIME_DIR=${HOST_RUNTIME_DIR}" \
  -e "WAYLAND_DISPLAY=${HOST_WAYLAND_DISPLAY}" \
  -e "TZ=${HOST_TIMEZONE}" \
  -e "WORK_CONTAINER_NODE_PROXY_PORT=${NODE_PROXY_PORT}" \
  -e "DBUS_SYSTEM_BUS_ADDRESS=unix:path=/run/dbus/system_bus_socket" \
  -e "PULSE_SERVER=unix:${HOST_RUNTIME_DIR}/pulse/native" \
  -p "127.0.0.1:${NODE_PROXY_PORT}:${NODE_PROXY_PORT}" \
  "${DISPLAY_ARGS[@]}" \
  "${IMAGE_NAME}" sleep infinity >/dev/null

PUBLIC_IP_LINE=""
for _ in $(seq 1 20); do
  PUBLIC_IP_LINE="$("${PODMAN_BIN[@]}" logs "${CONTAINER_NAME}" 2>/dev/null | awk '/Public egress IP:/ {line=$0} END {print line}')"
  if [[ -n "${PUBLIC_IP_LINE}" ]]; then
    break
  fi
  sleep 1
done

PROXY_STATUS_LINE="HTTP proxy: unavailable"
for _ in $(seq 1 20); do
  if ss -ltn 2>/dev/null | awk '{print $4}' | grep -Eq "127.0.0.1:${NODE_PROXY_PORT}$"; then
    PROXY_STATUS_LINE="HTTP proxy: http://127.0.0.1:${NODE_PROXY_PORT}"
    break
  fi

  PROXY_ERROR_LINE="$("${PODMAN_BIN[@]}" logs "${CONTAINER_NAME}" 2>/dev/null | awk '/tinyproxy failed to start|tinyproxy is unavailable|Missing template: .*HTTP proxy disabled/ {line=$0} END {print line}')"
  if [[ -n "${PROXY_ERROR_LINE}" ]]; then
    PROXY_STATUS_LINE="HTTP proxy: unavailable (${PROXY_ERROR_LINE})"
    break
  fi
  sleep 1
done

echo "Service started."
if [[ -n "${PUBLIC_IP_LINE}" ]]; then
  echo "${PUBLIC_IP_LINE}"
else
  echo "Public egress IP: unavailable"
fi
echo "${PROXY_STATUS_LINE}"
echo "Host runtime status:"
echo "${HOST_STATUS}"
echo "Use ./start service-status to check logs/state."
