#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
CONFIG_DIR="${PROJECT_DIR}/config"
source "${SCRIPT_DIR}/image-utils"

IMAGE_DIR="${WORK_CONTAINER_IMAGE_DIR:-${HOME}/.containers}"
NODE_PROXY_PORT=3128

if [[ -f "${CONFIG_DIR}/proxy.env" ]]; then
  # shellcheck disable=SC1090
  source "${CONFIG_DIR}/proxy.env"
  NODE_PROXY_PORT="${WORK_CONTAINER_NODE_PROXY_PORT:-3128}"
fi

if ! ps_names="$(sudo podman ps --format '{{.Names}}' 2>/dev/null)"; then
  echo "Cannot access root podman. Run ./start install (adds sudoers rule) or authenticate with: sudo -v"
  exit 1
fi

if grep -qx 'work_container' <<< "${ps_names}"; then
  container_logs="$(sudo podman logs --tail 200 work_container 2>/dev/null || true)"
  public_ip_line="$(awk '/Public egress IP:/ {line=$0} END {print line}' <<< "${container_logs}")"
  proxy_status_line="HTTP proxy: unavailable"
  if ss -ltn 2>/dev/null | awk '{print $4}' | grep -Eq "127.0.0.1:${NODE_PROXY_PORT}$"; then
    proxy_status_line="HTTP proxy: http://127.0.0.1:${NODE_PROXY_PORT}"
  fi

  echo "work_container service is running."
  if [[ -n "${public_ip_line}" ]]; then
    echo "${public_ip_line}"
  else
    echo "Public egress IP: unavailable"
  fi
  echo "${proxy_status_line}"
  sudo podman ps --filter name=work_container
  echo
  echo "Recent container logs:"
  echo "${container_logs}" | tail -n 40
  exit 0
fi

if [[ ! -d "${IMAGE_DIR}" ]]; then
  echo "work_container service is installed, but no payload directory found at ${IMAGE_DIR}."
  echo "Nothing to run yet."
  exit 0
fi

latest_image="$(find_latest_image "${IMAGE_DIR}")"
if [[ -z "${latest_image}" ]]; then
  echo "work_container service is installed, but no container image file is present in ${IMAGE_DIR}."
  echo "Nothing to run yet."
  exit 0
fi

echo "work_container service is not running."
exit 1
